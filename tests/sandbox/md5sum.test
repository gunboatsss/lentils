#!/bin/bash
# md5sum.test — Tests for the md5sum utility
# License: 0BSD
# Run via: run-sandbox-tests.sh md5sum


# md5sum of empty input
testing "md5sum empty" \
  'printf "" | "$UTIL"' \
  "d41d8cd98f00b204e9800998ecf8427e  -\n" "" ""

# md5sum of "hello"
testing "md5sum hello" \
  'printf "hello" | "$UTIL"' \
  "5d41402abc4b2a76b9719d911017c592  -\n" "" ""

# md5sum of "abc"
testing "md5sum abc" \
  'printf "abc" | "$UTIL"' \
  "900150983cd24fb0d6963f7d28e17f72  -\n" "" ""

# md5sum of a short string with newline
testing "md5sum with newline" \
  'printf "hello\n" | "$UTIL"' \
  "b1946ac92492d2347c6235b4d2611184  -\n" "" ""

# Multi-block input (65 bytes > 64 byte block)
testing "md5sum multi-block" \
  'printf "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" | "$UTIL"' \
  "c743a45e0d2e6a95cb859adae0248435  -\n" "" ""

# Binary data with null bytes
testing "md5sum binary-null" \
  'printf "hello\x00world" | "$UTIL"' \
  "838d3870873a75639041ff8940f397db  -\n" "" ""

# --check mode
testing "md5sum check" \
  'printf "" > input; "$UTIL" input > hashout; "$UTIL" -c hashout' \
  "input: OK\n" "" ""
