#!/bin/bash
# more.test — Tests for the `more` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh more


# Basic paging (short input, just passes through since no paging needed)
testing "more short" \
  'printf "hello\nworld\n" | "$UTIL"' \
  "hello\nworld\n" "" ""

# Empty input
testing "more empty" \
  'printf "" | "$UTIL"' \
  "" "" ""

# Single line
testing "more single line" \
  'printf "hello\n" | "$UTIL"' \
  "hello\n" "" ""

# Many lines (just check output count)
testing "more many lines" \
  'printf "line%d\n" $(seq 1 50) | "$UTIL"' \
  "" "" ""

# File argument
printf "file content\nline2\n" > more_input
testing "more file arg" \
  '"$UTIL" more_input' \
  "file content\nline2\n" "" ""
rm -f more_input

# Long lines
testing "more long lines" \
  'printf "a%.0s" $(seq 1 100) | "$UTIL"' \
  "" "" ""

# Trailing newline behavior
testing "more trailing newline" \
  'printf "hello" | "$UTIL"' \
  "hello\n" "" ""
