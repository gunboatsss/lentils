#!/bin/bash
# fold.test — Tests for the `fold` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh fold


# Basic fold at default width (80)
long=$(printf 'a%.0s' $(seq 1 100))
expected=$(printf 'a%.0s' $(seq 1 80))$'\n'$(printf 'a%.0s' $(seq 1 20))$'\n'
testing "fold default width" \
  '"$UTIL"' \
  "$expected" "" "$long"

# Fold at custom width with -w
short=$(printf 'x%.0s' $(seq 1 5))
line=$(printf 'x%.0s' $(seq 1 12))
expected=$(printf 'x%.0s' $(seq 1 5))$'\n'$(printf 'x%.0s' $(seq 1 5))$'\n'$(printf 'x%.0s' $(seq 1 2))$'\n'
testing "fold -w 5" \
  '"$UTIL" -w 5' \
  "$expected" "" "$line"

# Fold at width 1 (each char on its own line)
testing "fold -w 1" \
  '"$UTIL" -w 1' \
  "a\nb\nc\n" "" "abc"

# Fold with width equal to line length (no wrapping)
testing "fold width equal to line" \
  '"$UTIL" -w 5' \
  "hello\n" "" "hello"

# Fold with width greater than line length (no wrapping)
testing "fold width larger than line" \
  '"$UTIL" -w 10' \
  "hello\n" "" "hello"

# Empty input
testing "fold empty" \
  '"$UTIL"' \
  "" "" ""

# Fold with -s (break at spaces)
testing "fold -s break at spaces" \
  '"$UTIL" -w 10 -s' \
  "hello\nworld\n" "" "hello world"

# Fold -s with multiple spaces
testing "fold -s multiple spaces" \
  '"$UTIL" -w 5 -s' \
  "a b\nc d\ne\n" "" "a b c d e"

# Fold -s with no spaces (falls back to character break)
testing "fold -s no spaces" \
  '"$UTIL" -w 3 -s' \
  "abc\ndef\n" "" "abcdef"

# Fold at width 0? (should be treated as error or no-op)
testing "fold -w 0" \
  '"$UTIL" -w 0 2>folding_err; cat folding_err | sed "s|.*/fold|fold|"; rm -f folding_err; echo exit=$?' \
  "" "" ""

# Single newline only
testing "fold just newline" \
  '"$UTIL"' \
  "\n" "" "\n"

# Unicode characters (multi-byte)
testing "fold unicode" \
  '"$UTIL" -w 3' \
  "caf\né\n" "" "café"

# Multiple lines each needing folding
input=$(printf '1234567890\nabcdefghij\n')
expected=$(printf '12345\n67890\nabcde\nfghij\n')
testing "fold multi-line each" \
  '"$UTIL" -w 5' \
  "$expected" "" "$input"
