#!/bin/bash
# mkfifo.test — Tests for the `mkfifo` utility
# License: 0BSD

testing "mkfifo creates named pipe" \
  'rm -f f && "$UTIL" f && [ -p f ] && echo "pipe"' \
  "pipe\n" "" ""
testing "mkfifo missing operand" \
  '"$UTIL" 2>&1; echo $?' \
  "mkfifo: missing operand\nTry 'mkfifo --help' for more information.\n1\n" "" ""
testing "mkfifo already exists" \
  'rm -f f && "$UTIL" f && "$UTIL" f 2>&1; echo $?' \
  "mkfifo: cannot create fifo 'f': file exists (error code: 17)\n1\n" "" ""
