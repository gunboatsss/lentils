#!/bin/bash
# ptx.test — Tests for the `ptx` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh ptx


# Basic permuted index
testing "ptx basic" \
  'printf "hello world" | "$UTIL"' \
  "" "" ""

# Empty input
testing "ptx empty" \
  'printf "" | "$UTIL"' \
  "" "" ""

# Multiple words
testing "ptx multi word" \
  'printf "the quick brown fox" | "$UTIL"' \
  "" "" ""

# Single word
testing "ptx single word" \
  'printf "hello" | "$UTIL"' \
  "" "" ""

# File argument
printf "hello world\n" > ptx_input
testing "ptx file arg" \
  '"$UTIL" ptx_input' \
  "" "" ""
rm -f ptx_input
