#!/bin/bash
# tee.test — Tests for the `tee` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh tee


# Basic tee to stdout only (stdin passes through to stdout)
testing "tee stdin to stdout" \
  '"$UTIL"' \
  "hello\n" "" "hello\n"

# Tee to a file (stdout also gets a copy)
testing "tee to file and stdout" \
  '"$UTIL" outfile && cat outfile' \
  "data\ndata\n" "" "data\n"

# Tee to multiple files
testing "tee multiple files" \
  '"$UTIL" f1 f2 && cat f1 && echo . && cat f2' \
  "hello\n.\nhello\n" "" "hello\n"

# Tee with -a (append to existing file)
printf "original\n" > appendfile
testing "tee -a append" \
  '"$UTIL" -a appendfile > /dev/null && cat appendfile' \
  "original\nappended\n" "" "appended\n"
rm -f appendfile

# Empty input
testing "tee empty input" \
  '"$UTIL"' \
  "" "" ""
