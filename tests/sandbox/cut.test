#!/bin/bash
# cut.test — Tests for the `cut` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh cut

[ -f testing.sh ] && . testing.sh

# cut -c (character mode)
testing "cut -c 1" \
  'printf "hello\nworld\n" | "$UTIL" -c 1' \
  "h\nw\n" "" ""

testing "cut -c 1-3" \
  'printf "hello\nworld\n" | "$UTIL" -c 1-3' \
  "hel\nwor\n" "" ""

testing "cut -c 2-" \
  'printf "abc\ndef\n" | "$UTIL" -c 2-' \
  "bc\nef\n" "" ""

# cut -f (field mode) with default tab delimiter
testing "cut -f 1 with tab" \
  'printf "a\tb\nc\td\n" | "$UTIL" -f 1' \
  "a\nc\n" "" ""

testing "cut -f 2 with tab" \
  'printf "a\tb\nc\td\n" | "$UTIL" -f 2' \
  "b\nd\n" "" ""

# cut -s (suppress lines without delimiter)
testing "cut -s suppresses no-delim line" \
  'printf "a:b\nno_delim\nc:d\n" | "$UTIL" -d: -f 2 -s' \
  "b\nd\n" "" ""

testing "cut -s empty output when all lines lack delimiter" \
  'printf "no_delim\n" | "$UTIL" -d: -f 2 -s' \
  "" "" ""

testing "cut without -s passes no-delim line unchanged" \
  'printf "no_delim\n" | "$UTIL" -d: -f 2' \
  "no_delim\n" "" ""

