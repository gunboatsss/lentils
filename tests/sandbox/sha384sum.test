#!/bin/bash
# sha384sum.test — Tests for the `sha384sum` utility
# License: 0BSD

testing "sha384sum empty" \
  'printf "" | "$UTIL"' \
  "38b060a751ac96384cd9327eb1b1e36a21fdb71114be07434c0cc7bf63f6e1da274edebfe76f65fbd51ad2f14898b95b  -\n" "" ""
testing "sha384sum abc" \
  'printf "abc" | "$UTIL"' \
  "cb00753f45a35e8bb5a03d699ac65007272c32ab0eded1631a8b605a43ff5bed8086072ba1e7cc2358baeca134c825a7  -\n" "" ""
