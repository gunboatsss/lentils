#!/bin/bash
# grep.test — Tests for the `grep` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh grep

[ -f testing.sh ] && . testing.sh

# grep basic match
testing "grep basic" \
  'printf "hello\nworld\n" | "$UTIL" hello' \
  "hello\n" "" ""

# grep no match
testing "grep no match" \
  'printf "hello\nworld\n" | "$UTIL" nonexistent' \
  "" "" ""

# grep -v invert
testing "grep -v" \
  'printf "hello\nworld\n" | "$UTIL" -v hello' \
  "world\n" "" ""

# grep empty pattern (matches all)
testing "grep empty pattern" \
  'printf "hello\nworld\n" | "$UTIL" ""' \
  "hello\nworld\n" "" ""

# grep multiple matches
testing "grep multi" \
  'printf "apple\nbanana\napricot\n" | "$UTIL" ap' \
  "apple\napricot\n" "" ""

# --- Regex tests ---

# grep dot match
testing "grep dot match" \
  "printf 'cat\n' | \"\$UTIL\" 'c.t'" \
  "cat\n" "" ""

# grep dot no match
testing "grep dot no match" \
  "printf 'ct\n' | \"\$UTIL\" 'c.t'" \
  "" "" ""

# grep star match
testing "grep star match" \
  "printf 'aaa\n' | \"\$UTIL\" 'a*'" \
  "aaa\n" "" ""

# grep star backtrack
testing "grep star backtrack" \
  "printf 'hello world\n' | \"\$UTIL\" 'h.*d'" \
  "hello world\n" "" ""

# grep anchor start
testing "grep anchor start" \
  "printf 'hello\n' | \"\$UTIL\" '^hel'" \
  "hello\n" "" ""

# grep anchor start fail
testing "grep anchor start fail" \
  "printf 'hello\n' | \"\$UTIL\" '^ell'" \
  "" "" ""

# grep anchor end
testing "grep anchor end" \
  "printf 'hello\n' | \"\$UTIL\" 'lo\$'" \
  "hello\n" "" ""

# grep anchor end fail
testing "grep anchor end fail" \
  "printf 'hello\n' | \"\$UTIL\" 'hel\$'" \
  "" "" ""

# grep charclass match
testing "grep charclass match" \
  "printf 'cat\n' | \"\$UTIL\" '[abc]at'" \
  "cat\n" "" ""

# grep charclass no match
testing "grep charclass no match" \
  "printf 'dog\n' | \"\$UTIL\" '[abc]og'" \
  "" "" ""

# grep negated class
testing "grep negated class" \
  "printf 'dog\n' | \"\$UTIL\" '[^abc]og'" \
  "dog\n" "" ""

# grep escaped bracket
testing "grep escaped bracket" \
  "printf 'a[b\n' | \"\$UTIL\" 'a\\['" \
  "a[b\n" "" ""

# grep combined anchors
testing "grep combined anchors" \
  "printf 'hello world\n' | \"\$UTIL\" '^h.*\$'" \
  "hello world\n" "" ""

# grep regex with -v
testing "grep regex with -v" \
  "printf 'hello\nworld\n' | \"\$UTIL\" -v '^hel'" \
  "world\n" "" ""

# grep literal fallback
testing "grep literal fallback" \
  "printf 'hello\n' | \"\$UTIL\" hello" \
  "hello\n" "" ""

# --- -i / -c / -q tests ---

# grep -i case insensitive (lower matches upper)
testing "grep -i lowercase pattern" \
  "printf 'Hello\n' | \"\$UTIL\" -i hello" \
  "Hello\n" "" ""

# grep -i case insensitive (upper matches lower)
testing "grep -i uppercase pattern" \
  "printf 'hello\n' | \"\$UTIL\" -i HELLO" \
  "hello\n" "" ""

# grep -c count
testing "grep -c count" \
  "printf 'a\nb\na\n' | \"\$UTIL\" -c a" \
  "2\n" "" ""

# grep -c count no match
testing "grep -c count no match" \
  "printf 'a\nb\n' | \"\$UTIL\" -c x" \
  "0\n" "" ""

# grep -q quiet match
testing "grep -q quiet match" \
  "printf 'hello\n' | \"\$UTIL\" -q hello" \
  "" "" ""

# grep -q quiet no match
testing "grep -q quiet no match" \
  "printf 'hello\n' | \"\$UTIL\" -q xyz" \
  "" "" ""

# grep -ci combined
testing "grep -ci combined" \
  "printf 'Hello\nHELLO\nworld\n' | \"\$UTIL\" -ci hello" \
  "2\n" "" ""

# grep -cv invert count
testing "grep -cv invert count" \
  "printf 'a\nb\nc\n' | \"\$UTIL\" -cv a" \
  "2\n" "" ""


