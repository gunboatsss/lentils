#!/bin/bash
# grep.test — Tests for the `grep` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh grep


# ─── Basic regex matching ──────────────────────────────────────────────────────

# Basic substring match
testing "grep basic substring" \
  '"$UTIL" l' \
  "hello\nworld\n" "" "hello\nworld\n"

# Dot matches any single character (regex)
testing "grep dot wildcard" \
  '"$UTIL" "h.llo"' \
  "h.llo\nhello\n" "" "h.llo\nhello\n"

# Anchored start
testing "grep anchor start" \
  '"$UTIL" "^hello"' \
  "hello\nworld\n" "" "hello\nworld\n"

# Anchored end
testing "grep anchor end" \
  '"$UTIL" "world$"' \
  "hello\nworld\n" "" "hello\nworld\n"

# Star (zero or more)
testing "grep star" \
  '"$UTIL" "he*llo"' \
  "hello\nhllo\nhepello\n" "" "hello\nhllo\nhepello\n"

# Char class
testing "grep char class" \
  '"$UTIL" "[aeiou]"' \
  "sky\nhello\n" "" "hello\n"

# Negated char class
testing "grep negated char class" \
  '"$UTIL" "[^aeiou]"' \
  "a\nbc\n" "" "bc\n"

# No match -> empty output, exit 1
testing "grep no match" \
  '"$UTIL" "xyz"' \
  "" "" "hello\nworld\n"

# ─── -i ignore case ────────────────────────────────────────────────────────────

testing "grep -i ignore case" \
  '"$UTIL" -i "hello"' \
  "HELLO\n" "" "HELLO\n"

testing "grep -i ignore case lowercase pattern" \
  '"$UTIL" -i "HELLO"' \
  "hello\n" "" "hello\n"

# ─── -c count ──────────────────────────────────────────────────────────────────

testing "grep -c count" \
  '"$UTIL" -c "a"' \
  "2\n" "" "a\nb\na\n"

testing "grep -c count no match" \
  '"$UTIL" -c "z"' \
  "0\n" "" "a\nb\na\n"

# ─── -n line number ────────────────────────────────────────────────────────────

testing "grep -n line number" \
  '"$UTIL" -n "a"' \
  "1:a\n3:a\n" "" "a\nb\na\n"

# ─── -l files with matches ─────────────────────────────────────────────────────
# With stdin, GNU grep prints "(standard input)"
testing "grep -l files with matches (stdin)" \
  '"$UTIL" -l "cat"' \
  "(standard input)\n" "" "cat\ndog\n"

# ─── -q quiet ──────────────────────────────────────────────────────────────────

testing "grep -q quiet match (no output)" \
  '"$UTIL" -q "a"' \
  "" "" "a\nb\n"

testing "grep -q quiet no match (no output)" \
  '"$UTIL" -q "z"' \
  "" "" "a\nb\n"

# ─── -v invert ─────────────────────────────────────────────────────────────────

testing "grep -v invert" \
  '"$UTIL" -v "a"' \
  "b\n" "" "a\nb\n"

# ─── -w word match ─────────────────────────────────────────────────────────────

testing "grep -w word match" \
  '"$UTIL" -w "cat"' \
  "the cat sat\n" "" "the cat sat\ncategory\n"

# ─── -e explicit pattern ───────────────────────────────────────────────────────

testing "grep -e explicit pattern" \
  '"$UTIL" -e "foo"' \
  "foo\n" "" "foo\nbar\n"

# ─── -E extended regex (same engine as basic) ──────────────────────────────────

testing "grep -E extended alias dot" \
  '"$UTIL" -E "c.t"' \
  "cat\ncot\n" "" "cat\ncot\n"

testing "grep -E behaves like basic regex" \
  '"$UTIL" -E "h.llo"' \
  "h.llo\nhello\n" "" "h.llo\nhello\n"

# ─── -F fixed strings (literal, no regex metacharacters) ───────────────────────

# Literal dot must NOT be treated as a wildcard
testing "grep -F literal dot no match" \
  '"$UTIL" -F "h.llo"' \
  "" "" "hello\n"

testing "grep -F literal dot match" \
  '"$UTIL" -F "h.llo"' \
  "h.llo\n" "" "h.llo\n"

# Literal star must NOT be treated as repetition
testing "grep -F literal star" \
  '"$UTIL" -F "a*b"' \
  "a*b\n" "" "a*b\naXb\n"

# Literal anchors must NOT be treated as anchors
testing "grep -F literal caret" \
  '"$UTIL" -F "^abc"' \
  "^abc\n" "" "^abc\nxabc\n"

testing "grep -F literal dollar" \
  '"$UTIL" -F "abc$"' \
  "abc$\n" "" "abc$\nabcx\n"

# Combined with -i: case-insensitive literal match
testing "grep -F -i case insensitive literal" \
  '"$UTIL" -F -i "H.LLO"' \
  "h.llo\nH.LLO\n" "" "h.llo\nH.LLO\nhello\n"

# -F combined with -v inverts literal match
testing "grep -F -v invert literal" \
  '"$UTIL" -F -v "h.llo"' \
  "hello\n" "" "h.llo\nhello\n"
