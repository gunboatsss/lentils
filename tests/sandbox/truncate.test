#!/bin/bash
# truncate.test — Tests for the `truncate` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh truncate


# truncate requires -s flag
testing "truncate usage" '"$UTIL" 2>&1; echo $?' "1\n" "" ""

# truncate --help
testing "truncate help" '"$UTIL" --help 2>&1 | grep -q "truncate" && echo yes' "yes\n" "" ""

# truncate with no-create flag (no error on nonexistent)
testing "truncate no-create" '"$UTIL" -c -s 100 '"$TESTDIR/nonexistent_truncate_xyz"'; echo $?' "0\n" "" ""

# truncate creates a new file
testing "truncate create" '"$UTIL" -s 200 '"$TESTDIR/newfile_trunc"' 2>&1; test -f "$TESTDIR/newfile_trunc" && echo yes || echo no' "yes\n" "" ""

# truncate and check size
touch "$TESTDIR/tf_size"
testing "truncate shrink" '"$UTIL" -s 50 '"$TESTDIR/tf_size"' 2>&1; stat -c "%s" "$TESTDIR/tf_size"' "50\n" "" ""

# truncate to larger size (sparse)
testing "truncate extend" '"$UTIL" -s 5000 '"$TESTDIR/tf_size"' 2>&1; stat -c "%s" "$TESTDIR/tf_size"' "5000\n" "" ""

# truncate with reference file
echo "hello" > "$TESTDIR/ref_file"
testing "truncate reference" '"$UTIL" -r '"$TESTDIR/ref_file"' '"$TESTDIR/tf_ref"' 2>&1; stat -c "%s" "$TESTDIR/tf_ref"' "6\n" "" ""

# truncate with size zero
touch "$TESTDIR/tf_zero"
echo "data" > "$TESTDIR/tf_zero"
testing "truncate zero" '"$UTIL" -s 0 '"$TESTDIR/tf_zero"' 2>&1; stat -c "%s" "$TESTDIR/tf_zero"' "0\n" "" ""

# truncate with K suffix
testing "truncate K" '"$UTIL" -s 1K '"$TESTDIR/tf_k"' 2>&1; stat -c "%s" "$TESTDIR/tf_k"' "1024\n" "" ""

# truncate with M suffix
testing "truncate M" '"$UTIL" -s 1M '"$TESTDIR/tf_m"' 2>&1; stat -c "%s" "$TESTDIR/tf_m"' "1048576\n" "" ""
