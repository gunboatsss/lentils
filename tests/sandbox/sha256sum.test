#!/bin/bash
# sha256sum.test — Tests for the sha256sum utility
# License: 0BSD
# Run via: run-sandbox-tests.sh sha256sum

[ -f testing.sh ] && . testing.sh

# sha256sum of empty input
testing "sha256sum empty" \
  'printf "" | "$UTIL"' \
  "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855  -\n" "" ""

# sha256sum of "abc"
testing "sha256sum abc" \
  'printf "abc" | "$UTIL"' \
  "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad  -\n" "" ""

# sha256sum of "hello"
testing "sha256sum hello" \
  'printf "hello" | "$UTIL"' \
  "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824  -\n" "" ""

# Multi-block input (65 bytes > 64 byte block)
testing "sha256sum multi-block" \
  'printf "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" | "$UTIL"' \
  "635361c48bb9eab14198e76ea8ab7f1a41685d6ad62aa9146d301d4f17eb0ae0  -\n" "" ""

# Binary data with null bytes
testing "sha256sum binary-null" \
  'printf "hello\x00world" | "$UTIL"' \
  "b206899bc103669c8e7b36de29d73f95b46795b508aa87d612b2ce84bfb29df2  -\n" "" ""

# --check mode with file
testing "sha256sum check" \
  'printf "" > input; "$UTIL" input > hashout; "$UTIL" -c hashout' \
  "input: OK\n" "" ""
