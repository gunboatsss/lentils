#!/bin/bash
# test.test — Differential sandbox tests for the `test` utility.
# License: 0BSD
# Run via: run-sandbox-tests.sh test
#
# `test` produces no stdout; the differential harness compares exit
# codes (and empty stdout) between host /bin/test and lentils test.
# Each operator (-f, -d, -e, -s, -r, -w, -x) is exercised with both
# a positive and a negative case.


# ─── -f : path is a regular file ──────────────────────────────────────────────

# Positive: our wrapper script is a regular file.
testing "test -f regular file" \
  '"$UTIL" -f our_test' \
  "" "" ""

# Negative: a directory is not a regular file.
testing "test -f on directory" \
  '"$UTIL" -f testdir' \
  "" "" ""

# ─── -d : path is a directory ─────────────────────────────────────────────────

# Positive: testdir fixture is a directory.
testing "test -d directory" \
  '"$UTIL" -d testdir' \
  "" "" ""

# Negative: a regular file is not a directory.
testing "test -d on regular file" \
  '"$UTIL" -d our_test' \
  "" "" ""

# ─── -e : path exists ─────────────────────────────────────────────────────────

# Positive: an existing file exists.
testing "test -e existing file" \
  '"$UTIL" -e our_test' \
  "" "" ""

# Negative: a nonexistent path does not exist.
testing "test -e nonexistent" \
  '"$UTIL" -e /nonexistent_lentils_path_xyz' \
  "" "" ""

# ─── -s : path exists and has size > 0 ───────────────────────────────────────

# Positive: the wrapper script is non-empty.
testing "test -s nonempty file" \
  '"$UTIL" -s our_test' \
  "" "" ""

# Negative: an empty file has zero size.
testing "test -s empty file" \
  'touch __ls_emptyf; "$UTIL" -s __ls_emptyf' \
  "" "" ""

# Negative: a nonexistent path is not -s.
testing "test -s nonexistent" \
  '"$UTIL" -s /nonexistent_lentils_path_xyz' \
  "" "" ""

# ─── -r : path is readable ────────────────────────────────────────────────────

# Positive: the wrapper script is readable by the owner.
testing "test -r readable file" \
  '"$UTIL" -r our_test' \
  "" "" ""

# Negative: a nonexistent path is not readable.
testing "test -r nonexistent" \
  '"$UTIL" -r /nonexistent_lentils_path_xyz' \
  "" "" ""

# ─── -w : path is writable ────────────────────────────────────────────────────

# Positive: the wrapper script is writable by the owner.
testing "test -w writable file" \
  '"$UTIL" -w our_test' \
  "" "" ""

# Negative: a nonexistent path is not writable.
testing "test -w nonexistent" \
  '"$UTIL" -w /nonexistent_lentils_path_xyz' \
  "" "" ""

# ─── -x : path is executable ──────────────────────────────────────────────────

# Positive: the wrapper script has the execute bit set.
testing "test -x executable file" \
  '"$UTIL" -x our_test' \
  "" "" ""

# Negative: a freshly created file without the exec bit is not executable.
testing "test -x nonexecutable file" \
  'touch __ls_nonexec; "$UTIL" -x __ls_nonexec' \
  "" "" ""

# Negative: a nonexistent path is not executable.
testing "test -x nonexistent" \
  '"$UTIL" -x /nonexistent_lentils_path_xyz' \
  "" "" ""
