#!/bin/bash
# csplit.test — Tests for the `csplit` utility
# License: 0BSD

testing "csplit split at line 3" \
  'printf "a\nb\nc\nd\ne\n" > f.in && "$UTIL" f.in 3 > /dev/null && cat xx00 && echo "---" && cat xx01 && rm -f xx00 xx01 f.in' \
  "a\nb\n---\nc\nd\ne\n" "" ""
testing "csplit at lines 2 and 4" \
  'printf "a\nb\nc\nd\ne\n" > f.in && "$UTIL" f.in 2 4 > /dev/null && cat xx00 && echo "---" && cat xx01 && echo "---" && cat xx02 && rm -f xx0* f.in' \
  "a\n---\nb\nc\n---\nd\ne\n" "" ""
