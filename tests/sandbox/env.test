#!/bin/bash
# env.test — Tests for the `env` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh env

[ -f testing.sh ] && . testing.sh

# Run a command
testing "env run command" \
  '"$UTIL" echo hello' \
  "hello\n" "" ""

# Print environment (just check it has PATH)
testing "env print" \
  '"$UTIL" | grep "^PATH="' \
  "" "" ""

# Set a variable
testing "env FOO=bar printenv FOO" \
  '"$UTIL" FOO=bar printenv FOO 2>/dev/null || "$UTIL" FOO=bar env | grep "^FOO="' \
  "FOO=bar\n" "" ""

# -i with command
testing "env -i echo" \
  '"$UTIL" -i echo test' \
  "test\n" "" ""
