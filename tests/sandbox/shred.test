#!/bin/bash
# shred.test — Tests for the `shred` utility
# License: 0BSD

testing "shred overwrites file" \
  'rm -f f && printf "secret" > f && "$UTIL" -n 1 f 2>/dev/null && [ -f f ] && echo "shredded" && rm f' \
  "shredded\n" "" ""
testing "shred missing operand" \
  '"$UTIL" 2>&1; echo $?' \
  "shred: missing file operand\nTry 'shred --help" for more information.\n1\n" "" ""
