#!/bin/bash
# mesg.test — Tests for the `mesg` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh mesg
#
# In test commands:
#   $UTIL = the utility invocation (host: /bin/mesg, ours: <OUR_BINARY> mesg)
#
# Note: `mesg` requires a terminal. When stdin is not a terminal, it
# should print an error message and exit with status 1.

[ -f testing.sh ] && . testing.sh

# mesg with no args and no terminal should print error
testing "mesg not a terminal" \
  '"$UTIL" 2>&1; echo "EXIT:$?"' \
  "mesg: not a terminal\nEXIT:1\n" "" ""

# mesg with invalid argument
testing "mesg invalid arg" \
  '"$UTIL" x 2>&1; echo "EXIT:$?"' \
  "mesg: invalid argument 'x'\nUsage: mesg [y|n]\nEXIT:1\n" "" ""

# mesg with too many arguments
testing "mesg too many args" \
  '"$UTIL" y n 2>&1; echo "EXIT:$?"' \
  "mesg: too many arguments\nUsage: mesg [y|n]\nEXIT:1\n" "" ""
