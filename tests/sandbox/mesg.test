#!/bin/bash
# mesg.test — Tests for the `mesg` utility
# License: 0BSD
# Run via: run-sandbox-tests.sh mesg
#
# Note: mesg requires a tty. Our implementation handles non-tty differently
# from GNU mesg, so tests may differ on non-interactive runs.


# Query current state
testing "mesg query" \
  '"$UTIL"' \
  "" "" ""

# mesg y
testing "mesg y" \
  '"$UTIL" y; echo exit=$?' \
  "exit=0\n" "" ""

# mesg n
testing "mesg n" \
  '"$UTIL" n; echo exit=$?' \
  "exit=0\n" "" ""

# Too many args (should error)
testing "mesg too many args" \
  '"$UTIL" y n 2>/dev/null; echo exit=$?' \
  "exit=1\n" "" ""
